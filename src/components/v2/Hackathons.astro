---
import { hackathons } from '../../data/v2';
---

<section id="hackathons" class="v2-anchor max-w-6xl mx-auto px-4 md:px-8 py-20">
  <div data-reveal class="mb-12">
    <div class="w-16 h-1 bg-blue-600 rounded-full mb-4"></div>
    <h2 class="text-3xl md:text-4xl font-medium tracking-tight">Hackathons</h2>
    <p class="text-muted-foreground mt-2">Built and placed under the clock.</p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {hackathons.map((h, i) => (
      <div
        data-reveal
        class="flex flex-col rounded-2xl border-2 border-black dark:border-white bg-background p-6 hover:border-blue-600 dark:hover:border-blue-500 transition-colors duration-200"
        style={`--reveal-delay:${Math.min(i, 4) * 50}ms`}
      >
        <div class="flex items-start justify-between gap-3 mb-3">
          <h3 class="text-lg font-bold">{h.event}</h3>
          <div class="flex gap-2 shrink-0">
            {h.siteUrl && (
              <a
                href={h.siteUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 rounded-lg border border-foreground hover:bg-blue-600 hover:border-blue-600 hover:text-white transition-colors"
                aria-label={`Visit ${h.project}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 3h6v6" /><path d="M10 14 21 3" /><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6" />
                </svg>
              </a>
            )}
            {h.repoUrl && (
              <a
                href={h.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 rounded-lg border border-foreground hover:bg-blue-600 hover:border-blue-600 hover:text-white transition-colors"
                aria-label={`${h.project} on GitHub`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                  <path d="M9 18c-4.51 2-5-2-7-2" />
                </svg>
              </a>
            )}
          </div>
        </div>

        <p class="font-mono text-sm text-blue-600 dark:text-blue-400">&gt; {h.placement}</p>
        <p class="text-xs text-muted-foreground mt-1">{h.organizer} · {h.date}</p>
        <p class="text-muted-foreground text-sm leading-relaxed mt-3 flex-grow">{h.blurb}</p>

        <div class="flex flex-wrap gap-2 mt-5">
          <span class="px-3 py-1 text-xs rounded-full border border-foreground font-mono">Built {h.project}</span>
        </div>
      </div>
    ))}
  </div>
</section>
