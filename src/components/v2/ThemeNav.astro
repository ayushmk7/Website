---
// Token-driven nav shared by every theme page. Inherits the active theme's
// fonts/colors via CSS vars, so it reads as designed for each theme.
import { BB8Toggle } from './BB8Toggle';

const links = [
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#hackathons', label: 'Hackathons' },
  { href: '#skills', label: 'Stack' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="theme-nav-wrap fixed top-3 inset-x-0 z-40 flex justify-center px-4 pointer-events-none">
  <nav class="theme-nav pointer-events-auto flex items-center gap-1 px-2 py-1.5">
    <a href="#" class="theme-nav-brand px-4 py-1.5 mr-1 text-sm font-semibold" aria-label="Back to top">AMK</a>
    <span class="theme-nav-sep"></span>
    {links.map((l) => (
      <a href={l.href} class="theme-nav-link hidden sm:inline-block px-3 py-1.5 text-sm transition-colors">{l.label}</a>
    ))}
    <span class="theme-nav-sep hidden sm:inline-block"></span>
    <BB8Toggle client:load size="5px" />
  </nav>
</header>

<style>
  /* pin the nav to the viewport on every theme, above all theme overlays */
  .theme-nav-wrap {
    position: fixed !important;
    top: 0.75rem;
    left: 0;
    right: 0;
    z-index: 1000;
  }
  /* newspaper: paper + ink, thick ink outline, hard offset shadow */
  .theme-nav {
    background: var(--paper);
    border: 3px solid var(--ink);
    border-radius: 9999px;
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--ink);
    box-shadow: 4px 4px 0 var(--panel-shadow);
  }
  /* masthead-style brand: inverted ink block */
  .theme-nav-brand {
    font-family: var(--font-display);
    background: var(--accent-2);
    color: #141414;
    border: 2px solid var(--ink);
    border-radius: 9999px;
    letter-spacing: 0.06em;
    text-decoration: none;
  }
  .theme-nav-link {
    color: var(--ink);
    font-weight: 700;
    border-radius: 9999px;
    text-decoration: none;
  }
  .theme-nav-link:hover { background: var(--accent); color: #fff; }
  .theme-nav-sep {
    width: 2px;
    height: 1.25rem;
    margin: 0 0.25rem;
    background: var(--ink);
  }
</style>
