---
// Experience section — all layout variants, toggled by LayoutLab.
import { experience } from '../../data/v2';
const DEFAULT = 'accordion';
const hide = (v: string) => (v === DEFAULT ? undefined : 'display:none');
---
<!-- current: two-column cards -->
<div class="lv lv--exp" data-variant="current" style={hide('current')}>
  <div class="grid md:grid-cols-2" style="gap:1.5rem">
    {experience.map((j, i) => (
      <div class="panel" style={`padding:1.25rem 1.5rem;--i:${Math.min(i, 4)}`} data-load>
        <p class="text-sm" style="font-weight:600;margin-bottom:0.25rem">{j.period}</p>
        <h3 class="text-3xl text-[var(--accent)]" style="font-family:var(--font-display);line-height:1.1;margin-bottom:0.25rem">{j.company}</h3>
        <p style="font-weight:700;margin-bottom:0.75rem">{j.role}</p>
        <ul style="font-size:0.875rem;display:flex;flex-direction:column;gap:0.375rem;padding-left:1.1rem;list-style:disc">{j.bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
    ))}
  </div>
</div>

<!-- timeline: vertical rail with node markers -->
<div class="lv lv--exp" data-variant="timeline" style={hide('timeline')}>
  <div class="exp-timeline">
    {experience.map((j) => (
      <div class="exp-tl">
        <div class="vcard">
          <p class="vperiod">{j.period}</p>
          <h3 class="vco" style="font-size:1.6rem;margin:0.1rem 0 0.1rem">{j.company}{j.badge && <span class="vbadge">{j.badge}</span>}</h3>
          <p class="vrole" style="margin-bottom:0.6rem">{j.role}</p>
          <ul class="vbul">{j.bullets.map((b) => <li>{b}</li>)}</ul>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- terminal: console / git-log style -->
<div class="lv lv--exp" data-variant="terminal" style={hide('terminal')}>
  <div class="exp-terminal">
    <div class="t-bar"><span class="t-dot" style="background:#ff5f56"></span><span class="t-dot" style="background:#ffbd2e"></span><span class="t-dot" style="background:#27c93f"></span></div>
    {experience.map((j) => (
      <div class="t-row">
        <div><span class="t-cmd">$ career</span> <span class="t-arg">--at "{j.company}"</span> <span class="t-dim"># {j.period}</span></div>
        <div class="t-dim">role: {j.role}{j.badge ? ` · ${j.badge}` : ''}</div>
        {j.bullets.map((b) => <div class="t-out">{b}</div>)}
      </div>
    ))}
  </div>
</div>

<!-- filmstrip: horizontal scroll frames -->
<div class="lv lv--exp" data-variant="filmstrip" style={hide('filmstrip')}>
  <div class="exp-filmstrip">
    {experience.map((j) => (
      <div class="exp-frame vcard">
        <p class="vperiod">{j.period}</p>
        <h3 class="vco" style="font-size:1.5rem;margin:0.1rem 0">{j.company}{j.badge && <span class="vbadge">{j.badge}</span>}</h3>
        <p class="vrole" style="margin-bottom:0.6rem">{j.role}</p>
        <ul class="vbul">{j.bullets.map((b) => <li>{b}</li>)}</ul>
      </div>
    ))}
  </div>
</div>

<!-- accordion: collapsible per role -->
<div class="lv lv--exp" data-variant="accordion" style={hide('accordion')}>
  <div class="lv-acc">
    {experience.map((j, i) => (
      <details open={i === 0}>
        <summary><span class="acc-co">{j.company}</span> <span class="vrole">{j.role}</span>{j.badge && <span class="vbadge">{j.badge}</span>}<span class="acc-period">{j.period}</span></summary>
        <ul class="vbul">{j.bullets.map((b) => <li>{b}</li>)}</ul>
      </details>
    ))}
  </div>
</div>
