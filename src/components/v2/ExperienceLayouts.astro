---
// Experience — accordion (all collapsed by default).
import { experience } from '../../data/v2';
---
<div class="lv-acc">
  {experience.map((j) => (
    <details>
      <summary><span class="acc-co">{j.company}</span> <span class="vrole">{j.role}</span>{j.badge && <span class="vbadge">{j.badge}</span>}<span class="acc-period">{j.period}</span></summary>
      <ul class="vbul">{j.bullets.map((b) => <li>{b}</li>)}</ul>
    </details>
  ))}
</div>
