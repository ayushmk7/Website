---
import { experience } from '../../data/v2';
---

<section id="experience" class="v2-anchor max-w-4xl mx-auto px-4 md:px-8 py-20">
  <div data-reveal class="mb-12">
    <div class="w-16 h-1 bg-blue-600 rounded-full mb-4"></div>
    <h2 class="text-3xl md:text-4xl font-medium tracking-tight">Experience</h2>
    <p class="text-muted-foreground mt-2">Research, engineering, and industry roles.</p>
  </div>

  <ol class="relative border-l-2 border-black dark:border-white ml-4 md:ml-5 space-y-10">
    {experience.map((job, i) => (
      <li data-reveal class="relative pl-7 md:pl-9" style={`--reveal-delay:${Math.min(i, 4) * 60}ms`}>
        <span class="absolute -left-[7px] top-[1.35rem] h-3.5 w-3.5 rounded-full bg-blue-600 ring-4 ring-background"></span>
        <div class="rounded-2xl border-2 border-black dark:border-white bg-background p-5 md:p-6 hover:border-blue-600 dark:hover:border-blue-500 transition-colors duration-300">
          <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1">
            <div>
              <h3 class="text-lg md:text-xl font-bold leading-tight">
                {job.url ? (
                  <a href={job.url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors">{job.company}</a>
                ) : job.company}
              </h3>
              <p class="text-blue-600 dark:text-blue-400 font-medium">{job.role}</p>
            </div>
            <span class="text-sm text-foreground/60 whitespace-nowrap tabular-nums">{job.period}</span>
          </div>

          <div class="mt-2 flex flex-wrap items-center gap-2">
            <span class="text-[11px] uppercase tracking-wide font-semibold px-2 py-0.5 rounded-full border-2 border-black dark:border-white">
              {job.kind}
            </span>
            {job.location && <span class="text-xs text-foreground/60">{job.location}</span>}
          </div>

          <ul class="mt-4 space-y-2 list-none">
            {job.bullets.map((b) => (
              <li class="flex gap-2 leading-relaxed text-sm md:text-base">
                <span class="text-blue-600 dark:text-blue-400 mt-1.5 shrink-0">•</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </li>
    ))}
  </ol>
</section>
