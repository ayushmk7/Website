---
// Projects — newspaper cards in a varied-size bento grid.
import { projects } from '../../data/projects';
import { hackathons } from '../../data/v2';
import ProjectCard from './ProjectCard.astro';

const list = projects.filter((p) => !hackathons.some((h) => h.project === p.title));
---
<div class="np-bento">
  {list.map((p, i) => <ProjectCard p={p} i={i} />)}
</div>
