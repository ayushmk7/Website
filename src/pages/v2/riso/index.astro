---
// src/pages/v2/riso/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/riso.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const LABEL: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};

const skillEntries = Object.entries(resumeData.skills) as [string, string[]][];
---
<ThemeLayout themeKey="riso" title="Ayush Madhav Kumar. Risograph">
  <div class="grain"></div>

  <!-- HERO -->
  <section class="riso-hero flex flex-col justify-center max-w-5xl mx-auto px-6">
    <Photo class="riso-hero-photo" />
    <h1 class="misreg riso-hero-name" data-text="Ayush Madhav Kumar" style="font-family:var(--font-display);font-weight:800;" data-load>Ayush Madhav Kumar</h1>
    <p class="riso-hero-sub" data-load style="--i:1">CS and Math @UMichigan. Systems and AI infrastructure.</p>
    <p class="font-mono riso-hero-line" data-load style="--i:2;color:var(--text-dim)">&gt; NSF-backed research</p>
    <a class="riso-btn" href="/AyushMadhavResume.pdf" target="_blank" rel="noopener noreferrer" data-load style="--i:3;width:fit-content">
      <span aria-hidden="true">&gt;</span> view resume (pdf)
    </a>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="max-w-5xl mx-auto px-6 py-16" style="position:relative">
    <!-- ink blob accent -->
    <div class="riso-blob" style="width:280px;height:220px;background:var(--accent);top:-40px;right:-60px;"></div>
    <h2 class="misreg text-4xl mb-8 flex items-center" data-text="Experience" style="font-family:var(--font-display);font-weight:800">
      <span class="riso-reg-mark" aria-hidden="true"><span></span></span>
      Experience
    </h2>
    <div class="space-y-6" style="position:relative;z-index:1">
      {experience.map((j, i) => (
        <div class="riso-card" data-load style={`--i:${Math.min(i,4)}`}>
          <p class="font-mono" style="color:var(--text-dim)">{j.period}</p>
          <h3 class="text-xl mt-1" style="font-weight:800">{j.company} . {j.role}</h3>
          <ul class="mt-3 space-y-1.5">{j.bullets.map((b) => <li>{b}</li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="max-w-5xl mx-auto px-6 py-16" style="position:relative">
    <div class="riso-blob" style="width:320px;height:240px;background:var(--text);bottom:-60px;left:-80px;"></div>
    <h2 class="misreg text-4xl mb-8 flex items-center" data-text="Projects" style="font-family:var(--font-display);font-weight:800">
      <span class="riso-reg-mark" aria-hidden="true"><span></span></span>
      Projects
    </h2>
    <div class="grid md:grid-cols-2 gap-6" style="position:relative;z-index:1">
      {projects.filter((p) => !hackathons.some((h) => h.project === p.title)).map((p, i) => (
        <div class="riso-card" data-load style={`--i:${Math.min(i,4)}`}>
          <h3 class="text-lg" style="font-weight:800">{p.title}</h3>
          <p class="mt-2.5">{p.description}</p>
          {p.tags && p.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3">
              {p.tags.map((t) => (
                <span class="riso-chip">{t}</span>
              ))}
            </div>
          )}
          {(p.githubUrl || p.websiteUrl) && (
            <div class="flex gap-3 mt-4">
              {p.githubUrl && (
                <a href={p.githubUrl} target="_blank" rel="noopener noreferrer" class="riso-link-btn" aria-label={`${p.title} GitHub repository`}><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>
              )}
              {p.websiteUrl && (
                <a href={p.websiteUrl} target="_blank" rel="noopener noreferrer" class="riso-link-btn" aria-label={`${p.title} website`}><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- HACKATHONS -->
  <section id="hackathons" class="max-w-5xl mx-auto px-6 py-16" style="position:relative">
    <div class="riso-blob" style="width:260px;height:200px;background:var(--accent);top:20px;right:-40px;"></div>
    <h2 class="misreg text-4xl mb-8 flex items-center" data-text="Hackathons" style="font-family:var(--font-display);font-weight:800">
      <span class="riso-reg-mark" aria-hidden="true"><span></span></span>
      Hackathons
    </h2>
    <div class="grid md:grid-cols-2 gap-6" style="position:relative;z-index:1">
      {hackathons.map((h, i) => (
        <div class="riso-card" data-load style={`--i:${Math.min(i,4)}`}>
          <p class="font-mono" style="color:var(--text-dim)">&gt; {h.placement}</p>
          <h3 class="text-lg mt-1" style="font-weight:800">{h.event}</h3>
          <p class="mt-2.5">{h.blurb}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="max-w-5xl mx-auto px-6 py-16" style="position:relative">
    <div class="riso-blob" style="width:300px;height:230px;background:var(--text);bottom:-40px;right:-60px;"></div>
    <h2 class="misreg text-4xl mb-8 flex items-center" data-text="Stack" style="font-family:var(--font-display);font-weight:800">
      <span class="riso-reg-mark" aria-hidden="true"><span></span></span>
      Stack
    </h2>
    <div class="space-y-8" style="position:relative;z-index:1">
      {skillEntries.map(([key, items]) => (
        <div>
          <p class="font-mono text-sm mb-3" style="color:var(--text-dim)">&gt; {LABEL[key] ?? key}</p>
          <div class="flex flex-wrap gap-2">
            {items.map((s) => (
              <span class="riso-chip">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CONTACT -->
  <footer id="contact" class="max-w-5xl mx-auto px-6 py-16 text-center" style="position:relative">
    <div class="riso-blob" style="width:350px;height:280px;background:var(--accent);top:-60px;left:50%;transform:translateX(-50%);"></div>
    <h2 class="misreg text-4xl mb-8 flex items-center justify-center" data-text="Contact" style="font-family:var(--font-display);font-weight:800">
      <span class="riso-reg-mark" aria-hidden="true"><span></span></span>
      Contact
    </h2>
    <div style="position:relative;z-index:1">
      <ThemeContact client:load />
    </div>
  </footer>
</ThemeLayout>
