---
import V2Layout from '../../layouts/V2Layout.astro';
import Hero from '../../components/v2/Hero';
import Experience from '../../components/v2/Experience.astro';
import ProjectsV2 from '../../components/v2/ProjectsV2';
import Hackathons from '../../components/v2/Hackathons.astro';
import Skills from '../../components/v2/Skills.astro';
import ContactFooter from '../../components/ContactFooter';
import { ThemeDock } from '../../components/v2/ThemeDock';
---

<V2Layout title="Ayush Madhav Kumar, Systems and AI Infrastructure">
  <Hero client:load />
  <script is:inline>
    try {
      const saved = localStorage.getItem('v2-theme');
      if (saved && saved !== 'current' && !location.search.includes('stay')) {
        const r = {"blueprint":"/v2/blueprint","terminal":"/v2/terminal","editorial":"/v2/editorial","brutal":"/v2/brutal","riso":"/v2/riso","outrun":"/v2/outrun","aurora":"/v2/aurora","bauhaus":"/v2/bauhaus","comic":"/v2/comic"}[saved];
        if (r) location.replace(r);
      }
    } catch (e) {}
  </script>
  <ThemeDock client:load current="current" />

  <Experience />

  <!-- Projects -->
  <section id="projects" class="v2-anchor max-w-6xl mx-auto px-4 md:px-8 py-20">
    <div data-reveal class="mb-12">
      <div class="w-16 h-1 bg-blue-600 rounded-full mb-4"></div>
      <h2 class="text-3xl md:text-4xl font-medium tracking-tight">Projects</h2>
      <p class="text-muted-foreground mt-2">Shipped, open-sourced, and occasionally award-winning.</p>
    </div>
    <div data-reveal>
      <ProjectsV2 client:load />
    </div>
  </section>

  <Hackathons />

  <Skills />

  <!-- Contact -->
  <section id="contact" class="v2-anchor border-t border-border mt-12">
    <div data-reveal>
      <ContactFooter client:load />
    </div>
  </section>
</V2Layout>
