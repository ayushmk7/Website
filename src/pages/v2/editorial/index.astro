---
// src/pages/v2/editorial/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/editorial.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const categoryLabels: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};
---
<ThemeLayout themeKey="editorial" title="Ayush Madhav Kumar. Editorial">
  <section class="ed-hero">
    <div class="ed-hero__inner max-w-5xl mx-auto px-6">
      <div class="ed-hero__grid">
        <div class="ed-hero__text order-2 md:order-1">
          <h1 class="ed-hero__name leading-[0.95] mt-4" style="font-family:var(--font-display);font-weight:900;--i:1" data-load>Ayush<br/>Madhav Kumar</h1>
          <p class="dropcap ed-hero__body leading-relaxed max-w-prose mt-4" data-load style="--i:2">
            CS and Math at the University of Michigan working in systems programming and AI infrastructure: on-device inference engines, fine-tuned coding agents, and the tooling around them. NSF-backed research; contributor at Cactus (YC S25).
          </p>
          <a href="/AyushMadhavResume.pdf" target="_blank" rel="noopener noreferrer" class="editorial-link inline-block mt-4" data-load style="--i:3">View resume</a>
        </div>
        <Photo class="ed-hero__photo order-1 md:order-2 md:justify-self-end" />
      </div>
    </div>
  </section>

  <!-- section 01: experience -->
  <div class="ed-dinkus max-w-5xl mx-auto px-6"><span>* * *</span></div>

  <section id="experience" class="rule max-w-5xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-[120px_1fr] gap-6">
      <p class="ed-num">01</p>
      <div>
        <span class="ed-rule-draw" data-rule></span>
        <h2 class="text-3xl mb-8 mt-1" style="font-family:var(--font-display);font-weight:900">Experience</h2>
        {experience.map((j, i) => (
          <div class="mb-8 max-w-prose" data-load style={`--i:${Math.min(i,4)}`}>
            <h3 class="text-xl" style="font-family:var(--font-display);font-weight:900">{j.company}</h3>
            <p class="italic text-[var(--text-dim)]" style="font-family:var(--font-display)">{j.role} . {j.period}</p>
            <ul class="mt-2 space-y-1">{j.bullets.map((b) => <li>{b}</li>)}</ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- section 02: projects -->
  <div class="ed-dinkus max-w-5xl mx-auto px-6"><span>* * *</span></div>

  <section id="projects" class="rule max-w-5xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-[120px_1fr] gap-6">
      <p class="ed-num">02</p>
      <div>
        <span class="ed-rule-draw" data-rule></span>
        <h2 class="text-3xl mb-8 mt-1" style="font-family:var(--font-display);font-weight:900">Projects</h2>
        <blockquote class="ed-pull">
          Built for depth, not breadth: systems that run close to the metal.
        </blockquote>
        <div class="columns-1 md:columns-2 gap-10">
          {projects.filter((p) => !hackathons.some((h) => h.project === p.title)).map((p) => (
            <div class="mb-6 break-inside-avoid">
              <h3 class="text-lg" style="font-family:var(--font-display);font-weight:900">{p.title}</h3>
              <p class="text-[var(--text-dim)] mt-1">{p.description}</p>
              {(p.githubUrl || p.websiteUrl) && (
                <p class="mt-2 flex gap-4 flex-wrap">
                  {p.githubUrl && (
                    <a href={p.githubUrl} target="_blank" rel="noopener noreferrer" class="editorial-link">GitHub</a>
                  )}
                  {p.websiteUrl && (
                    <a href={p.websiteUrl} target="_blank" rel="noopener noreferrer" class="editorial-link">Site</a>
                  )}
                </p>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- section 03: hackathons -->
  <div class="ed-dinkus max-w-5xl mx-auto px-6"><span>* * *</span></div>

  <section id="hackathons" class="rule max-w-5xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-[120px_1fr] gap-6">
      <p class="ed-num">03</p>
      <div>
        <span class="ed-rule-draw" data-rule></span>
        <h2 class="text-3xl mb-8 mt-1" style="font-family:var(--font-display);font-weight:900">Hackathons</h2>
        {hackathons.map((h) => (
          <div class="mb-6 max-w-prose">
            <p class="italic text-[var(--accent)]" style="font-family:var(--font-display)">{h.placement}</p>
            <h3 class="text-lg" style="font-family:var(--font-display);font-weight:900">{h.event}</h3>
            <p class="text-[var(--text-dim)]">{h.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- section 04: stack -->
  <div class="ed-dinkus max-w-5xl mx-auto px-6"><span>* * *</span></div>

  <section id="skills" class="rule max-w-5xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-[120px_1fr] gap-6">
      <p class="ed-num">04</p>
      <div>
        <span class="ed-rule-draw" data-rule></span>
        <h2 class="text-3xl mb-8 mt-1" style="font-family:var(--font-display);font-weight:900">Stack</h2>
        {Object.entries(resumeData.skills).map(([k, items]) => (
          <div class="mb-4 max-w-prose">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--text-dim)] mb-1" style="font-family:var(--font-display)">{categoryLabels[k] ?? k}</p>
            <p>{(items as string[]).join(', ')}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- section 05: contact -->
  <div class="ed-dinkus max-w-5xl mx-auto px-6"><span>* * *</span></div>

  <footer id="contact" class="rule max-w-5xl mx-auto px-6 py-20 text-center">
    <h2 class="text-3xl mb-8" style="font-family:var(--font-display);font-weight:900">Contact</h2>
    <ThemeContact client:load />
  </footer>
</ThemeLayout>

<script>
  // Rule-draw: sweep accent line across on scroll into view
  const rules = document.querySelectorAll<HTMLElement>('[data-rule]');
  if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    rules.forEach((r) => obs.observe(r));
  } else {
    rules.forEach((r) => r.classList.add('is-visible'));
  }
</script>
