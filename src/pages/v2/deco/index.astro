---
// src/pages/v2/deco/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/deco.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const CATEGORY_LABELS: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};

const filteredProjects = projects.filter(
  (p) => !hackathons.some((h) => h.project === p.title)
);
---

<ThemeLayout themeKey="deco" title="Ayush Madhav Kumar. Art Deco">

  <!-- ═══════════════════════ HERO ═══════════════════════════ -->
  <section class="deco-hero px-6" aria-label="Introduction">

    <!-- mobile: photo above name; smaller on very short screens -->
    <Photo class="md:hidden object-cover" data-load style="--i:0; width:clamp(4rem,14svh,7rem); height:clamp(5rem,18svh,9rem)" />

    <!-- sunburst above name -->
    <div class="deco-sunburst mx-auto" aria-hidden="true"></div>

    <!-- name: clamp scales from ~1.15rem on 360px up to 4.5rem on desktop -->
    <h1
      class="deco-heading leading-tight"
      data-load
      style="--i:1; font-size:clamp(1.15rem,5vw,4.5rem); letter-spacing:clamp(0.04em,0.8vw,0.2em); margin-bottom:clamp(0.1rem,0.6svh,0.5rem)"
    >
      Ayush Madhav Kumar
    </h1>

    <!-- double-rule -->
    <div class="deco-rule w-full max-w-lg mx-auto" aria-hidden="true">
      <span class="deco-rule-span">CS &amp; Math</span>
    </div>

    <!-- role + callout row -->
    <div class="flex flex-col items-center" data-load style="--i:2; gap:clamp(0.1rem,0.5svh,0.5rem); margin-bottom:clamp(0.4rem,2svh,1.5rem)">
      <p
        class="tracking-[0.25em] uppercase text-[var(--text)]"
        style="font-family:var(--font-display); font-size:clamp(0.65rem,1.8vw,0.875rem)"
      >
        CS and Math @UMichigan
      </p>
      <p
        class="tracking-[0.2em] uppercase text-[var(--accent-2)]"
        style="font-family:var(--font-display); font-size:clamp(0.6rem,1.5vw,0.75rem)"
      >
        &gt; NSF-backed research
      </p>
    </div>

    <!-- desktop photo + blurb row -->
    <div
      class="hidden md:flex items-center gap-8 max-w-3xl mx-auto"
      data-load
      style="--i:3"
    >
      <Photo class="flex-shrink-0" style="width:clamp(5rem,8vw,7rem); height:clamp(6.25rem,10vw,9rem)" />
      <p class="text-[var(--text)] leading-relaxed max-w-prose text-left" style="font-size:clamp(0.75rem,1.2vw,0.9375rem)">
        Systems programming and AI infrastructure: on-device inference engines, fine-tuned
        coding agents, and the tooling around them. NSF-backed research; contributor at
        Cactus (YC S25).
        <a
          href="/AyushMadhavResume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="deco-btn"
          style="font-size:clamp(0.55rem,0.9vw,0.65rem); margin-top:clamp(0.25rem,1svh,0.75rem)"
        >
          <span class="deco-btn-inner">View Resume</span>
        </a>
      </p>
    </div>

    <!-- mobile blurb -->
    <p
      class="md:hidden text-[var(--text)] leading-relaxed max-w-prose text-center"
      data-load
      style="--i:3; font-size:clamp(0.7rem,3.5vw,0.875rem); margin-top:clamp(0.25rem,1svh,1rem)"
    >
      Systems programming and AI infrastructure: on-device inference engines, fine-tuned
      coding agents, and the tooling around them.
      <a
        href="/AyushMadhavResume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="deco-btn mx-auto"
        style="font-size:clamp(0.55rem,2.2vw,0.65rem); margin-top:clamp(0.25rem,1svh,0.75rem)"
      >
        <span class="deco-btn-inner">View Resume</span>
      </a>
    </p>

    <!-- bottom triple-chevron -->
    <div class="deco-chevron-triple" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════ EXPERIENCE ════════════════════ -->
  <section id="experience" class="deco-section-rule max-w-4xl mx-auto px-6 py-20">

    <!-- section heading -->
    <div class="text-center mb-12" data-load style="--i:0">
      <p class="deco-heading text-[0.6rem] tracking-[0.4em] text-[var(--accent-text)] mb-2">I</p>
      <h2 class="deco-heading text-2xl md:text-3xl">Experience</h2>
      <div class="deco-rule w-64 mx-auto mt-4" aria-hidden="true">
        <span class="deco-rule-span" aria-hidden="true">&#9670;</span>
      </div>
    </div>

    <div class="space-y-8">
      {experience.map((j, i) => (
        <div class="deco-card" data-load style={`--i:${Math.min(i, 5)}`}>
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
            <h3
              class="deco-heading text-base tracking-[0.15em]"
              style="font-family:var(--font-display)"
            >
              {j.company}
            </h3>
            {j.badge && <span class="deco-badge">{j.badge}</span>}
          </div>
          <p
            class="text-[var(--accent-text)] text-xs tracking-widest uppercase mb-3"
            style="font-family:var(--font-display)"
          >
            {j.role} &middot; {j.period}{j.location ? ` &middot; ${j.location}` : ''}
          </p>
          <ul class="space-y-1 text-sm text-[var(--text)]">
            {j.bullets.map((b) => (
              <li class="flex gap-2 items-start">
                <span class="deco-diamond" aria-hidden="true"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ PROJECTS ══════════════════════ -->
  <section id="projects" class="deco-section-rule max-w-4xl mx-auto px-6 py-20">

    <div class="text-center mb-12" data-load style="--i:0">
      <p class="deco-heading text-[0.6rem] tracking-[0.4em] text-[var(--accent-text)] mb-2">II</p>
      <h2 class="deco-heading text-2xl md:text-3xl">Projects</h2>
      <div class="deco-rule w-64 mx-auto mt-4" aria-hidden="true">
        <span class="deco-rule-span" aria-hidden="true">&#9670;</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {filteredProjects.map((p, i) => (
        <div class="deco-ziggurat" data-load style={`--i:${Math.min(i, 5)}`}>
          <h3
            class="deco-heading text-sm tracking-[0.18em] mb-2"
            style="font-family:var(--font-display)"
          >
            {p.title}
          </h3>
          <p class="text-[var(--text)] text-sm leading-relaxed mb-3">{p.description}</p>
          <div class="flex flex-wrap gap-2 mb-3">
            {p.tags.slice(0, 4).map((t) => (
              <span class="deco-tag">{t}</span>
            ))}
          </div>
          {(p.githubUrl || p.websiteUrl) && (
            <div class="flex gap-3 flex-wrap">
              {p.githubUrl && (
                <a
                  href={p.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="deco-btn"
                  style="font-size:0.58rem"
                >
                  <span class="deco-btn-inner">GitHub</span>
                </a>
              )}
              {p.websiteUrl && (
                <a
                  href={p.websiteUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="deco-btn"
                  style="font-size:0.58rem; color:var(--accent-2)"
                >
                  <span class="deco-btn-inner">Live</span>
                </a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ HACKATHONS ════════════════════ -->
  <section id="hackathons" class="deco-section-rule max-w-4xl mx-auto px-6 py-20">

    <div class="text-center mb-12" data-load style="--i:0">
      <p class="deco-heading text-[0.6rem] tracking-[0.4em] text-[var(--accent-text)] mb-2">III</p>
      <h2 class="deco-heading text-2xl md:text-3xl">Hackathons</h2>
      <div class="deco-rule w-64 mx-auto mt-4" aria-hidden="true">
        <span class="deco-rule-span" aria-hidden="true">&#9670;</span>
      </div>
    </div>

    <div class="space-y-6">
      {hackathons.map((h, i) => (
        <div class="deco-card" data-load style={`--i:${Math.min(i, 4)}`}>
          <p
            class="text-[var(--accent-text)] text-xs tracking-[0.25em] uppercase mb-1"
            style="font-family:var(--font-display)"
          >
            {h.placement}
          </p>
          <h3
            class="deco-heading text-sm tracking-[0.15em] mb-1"
            style="font-family:var(--font-display)"
          >
            {h.project} . {h.event}
          </h3>
          <p
            class="text-[var(--text-dim)] text-xs tracking-widest uppercase mb-2"
            style="font-family:var(--font-display)"
          >
            {h.organizer} &middot; {h.date}
          </p>
          <p class="text-sm text-[var(--text)] leading-relaxed mb-3">{h.blurb}</p>
          {(h.repoUrl || h.siteUrl) && (
            <div class="flex gap-3 flex-wrap">
              {h.repoUrl && (
                <a
                  href={h.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="deco-btn"
                  style="font-size:0.58rem"
                >
                  <span class="deco-btn-inner">GitHub</span>
                </a>
              )}
              {h.siteUrl && (
                <a
                  href={h.siteUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="deco-btn"
                  style="font-size:0.58rem; color:var(--accent-2)"
                >
                  <span class="deco-btn-inner">Live</span>
                </a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ SKILLS ════════════════════════ -->
  <section id="skills" class="deco-section-rule max-w-4xl mx-auto px-6 py-20">

    <div class="text-center mb-12" data-load style="--i:0">
      <p class="deco-heading text-[0.6rem] tracking-[0.4em] text-[var(--accent-text)] mb-2">IV</p>
      <h2 class="deco-heading text-2xl md:text-3xl">Stack</h2>
      <div class="deco-rule w-64 mx-auto mt-4" aria-hidden="true">
        <span class="deco-rule-span" aria-hidden="true">&#9670;</span>
      </div>
    </div>

    <div class="space-y-6">
      {Object.entries(resumeData.skills).map(([category, items], i) => (
        <div data-load style={`--i:${Math.min(i, 4)}`}>
          <div class="deco-rule mb-3">
            <span class="deco-rule-span">{CATEGORY_LABELS[category] ?? category}</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {(items as string[]).map((item) => (
              <span class="deco-tag">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════ CONTACT ═══════════════════════ -->
  <footer
    id="contact"
    class="deco-section-rule max-w-4xl mx-auto px-6 py-24 text-center"
    data-load
    style="--i:0"
  >
    <div class="deco-sunburst mb-6 mx-auto" aria-hidden="true"></div>
    <p
      class="deco-heading text-[0.6rem] tracking-[0.5em] text-[var(--accent-text)] mb-4"
    >
      Get In Touch
    </p>
    <div class="deco-rule w-56 mx-auto mb-6" aria-hidden="true">
      <span class="deco-rule-span" aria-hidden="true">&#9670;</span>
    </div>
    <div class="deco-heading text-xl md:text-2xl" style="font-family:var(--font-display); letter-spacing:0.1em">
      <ThemeContact client:load />
    </div>
    <div class="deco-chevron-triple mt-8 mx-auto" aria-hidden="true"></div>
  </footer>

  <script>
    // Shimmer sweep on section rules when they enter the viewport.
    // Reduced-motion: the CSS guard removes the animation, so this is safe.
    if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const rules = e.target.querySelectorAll<HTMLElement>('.deco-rule');
          rules.forEach((r) => {
            r.classList.add('deco-rule-shimmer');
            r.addEventListener('animationend', () => r.classList.remove('deco-rule-shimmer'), { once: true });
          });
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.deco-section-rule').forEach((s) => io.observe(s));
    }
  </script>

</ThemeLayout>
