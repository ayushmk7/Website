---
// src/pages/v2/terminal/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/terminal.css';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';
const prompt = 'ayush@umich:~$';
---
<ThemeLayout themeKey="terminal" title="Ayush Madhav Kumar. Phosphor">
  <main class="max-w-4xl mx-auto px-4 leading-relaxed text-sm md:text-base">
    <section class="hero-section flex flex-col justify-center min-h-[100svh] min-h-[100dvh] py-8">
      <p data-load style="--i:0">{prompt} whoami</p>
      <pre data-load style="--i:1" class="text-2xl md:text-4xl my-2 whitespace-pre-wrap break-words">Ayush Madhav Kumar</pre>
      <p data-load style="--i:2" class="text-[var(--text-dim)]">CS and Math @UMichigan . Ann Arbor, MI</p>
      <p data-load style="--i:3" class="caret">&gt; NSF-backed research</p>
    </section>

    <p class="mt-10" data-load style="--i:4">{prompt} cat experience.md</p>
    {experience.map((j, i) => (
      <div class="mt-3" data-load style={`--i:${5+Math.min(i,4)}`}>
        <p class="text-[var(--accent)] break-words"># {j.company} . {j.role} . {j.period}</p>
        {j.bullets.map((b) => <p class="text-[var(--text-dim)] break-words">- {b}</p>)}
      </div>
    ))}

    <p class="mt-10" data-load style="--i:10">{prompt} ls hackathons/</p>
    {hackathons.map((h, i) => (
      <p data-load style={`--i:${11+Math.min(i,3)}`} class="break-words">[{h.placement}] <span class="text-[var(--accent)]">{h.event}</span> -&gt; {h.project}</p>
    ))}

    <p class="mt-10" data-load style="--i:15">{prompt} ls projects/</p>
    <div class="grid md:grid-cols-2 gap-x-8 mt-2" data-load style="--i:16">
      {projects.filter((p) => !hackathons.some((h) => h.project === p.title)).map((p) => (
        <p class="break-words">{p.title} <span class="text-[var(--text-dim)]"># {p.tags.slice(0,3).join(',')}</span></p>
      ))}
    </div>

    <p class="mt-10" data-load style="--i:17">{prompt} cat stack.txt</p>
    {Object.entries(resumeData.skills).map(([k, items], i) => (
      <p data-load style={`--i:${18+Math.min(i,4)}`} class="break-words"><span class="text-[var(--accent)]">{k}:</span> {items.join(' ')}</p>
    ))}

    <p class="mt-10 mb-8 caret" id="contact" data-load style="--i:23">{prompt} mail contactayushmadhav@gmail.com </p>
  </main>
</ThemeLayout>
