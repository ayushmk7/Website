---
// src/pages/v2/outrun/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/outrun.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const LABEL_MAP: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};
---
<ThemeLayout themeKey="outrun" title="Ayush Madhav Kumar. Outrun">
  <div class="horizon" aria-hidden="true"></div>

  <section class="hero-viewport flex flex-col items-center justify-center text-center px-6">
    <Photo class="hero-avatar rounded-lg border-2 border-[var(--accent)] shadow-[0_0_24px_rgba(255,46,151,0.45)]" />
    <p class="hero-subtitle" data-load>CS and Math @UMichigan</p>
    <span class="outrun-sun" aria-hidden="true"></span>
    <h1 class="glow hero-name uppercase" style="font-family:var(--font-display);font-weight:900;letter-spacing:0.05em;color:var(--accent);--i:1" data-load>Ayush Madhav Kumar</h1>
    <p class="font-mono hero-tagline" data-load style="--i:2">&gt; NSF-backed research</p>
    <div class="hero-cta-row" data-load style="--i:3">
      <a class="btn-outrun hero-cta" href="/AyushMadhavResume.pdf" target="_blank" rel="noopener noreferrer">Resume</a>
      <a class="btn-outrun-sm" href="https://github.com/ayushmk7" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile" style="min-width:2.25rem;min-height:2.25rem;padding:0.35rem 0.65rem;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>
      <a class="btn-outrun-sm" href="https://www.linkedin.com/in/ayushmk" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile" style="min-width:2.25rem;min-height:2.25rem;padding:0.35rem 0.65rem;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
    </div>
  </section>

  <section id="experience" class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="glow text-4xl uppercase section-heading" style="font-family:var(--font-display)">Experience</h2>
    <div class="grid md:grid-cols-2 section-grid-2">
      {experience.map((j, i) => (
        <div class="border border-[var(--accent)] bg-[var(--surface)] backdrop-blur p-6 rounded-lg" data-load style={`--i:${Math.min(i,4)}`}>
          <p class="card-period text-[var(--accent-2)] uppercase tracking-wide text-sm">{j.period}</p>
          <h3 class="text-xl uppercase" style="font-family:var(--font-display)">{j.company}</h3>
          <p>{j.role}</p>
          <ul class="space-y-1 text-[var(--text-dim)]">{j.bullets.map((b) => <li>- {b}</li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  <section id="projects" class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="glow text-4xl uppercase section-heading" style="font-family:var(--font-display)">Projects</h2>
    <div class="grid md:grid-cols-3 section-grid-3">
      {projects.filter((p) => !hackathons.some((h) => h.project === p.title)).map((p, i) => (
        <div class="border border-[var(--accent)] bg-[var(--surface)] backdrop-blur p-6 rounded-lg flex flex-col" data-load style={`--i:${Math.min(i,4)}`}>
          <h3 class="uppercase" style="font-family:var(--font-display)">{p.title}</h3>
          <p class="text-[var(--text-dim)] flex-1">{p.description}</p>
          {(p.githubUrl || p.websiteUrl) && (
            <div class="card-links flex flex-wrap">
              {p.githubUrl && (
                <a href={p.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-outrun-sm" aria-label={`${p.title} GitHub repository`} style="min-width:2.25rem;min-height:2.25rem;padding:0.35rem 0.65rem;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>
              )}
              {p.websiteUrl && (
                <a href={p.websiteUrl} target="_blank" rel="noopener noreferrer" class="btn-outrun-sm alt" aria-label={`${p.title} live site`} style="min-width:2.25rem;min-height:2.25rem;padding:0.35rem 0.65rem;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <section id="hackathons" class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="glow text-4xl uppercase section-heading" style="font-family:var(--font-display)">Hackathons</h2>
    <div class="grid md:grid-cols-2 section-grid-2">
      {hackathons.map((h, i) => (
        <div class="border border-[var(--accent)] bg-[var(--surface)] backdrop-blur p-6 rounded-lg" data-load style={`--i:${Math.min(i,4)}`}>
          <p class="card-placement text-[var(--accent-2)] uppercase text-sm">{h.placement}</p>
          <h3 class="uppercase" style="font-family:var(--font-display)">{h.event}</h3>
          <p class="text-[var(--text-dim)]">{h.blurb}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="skills" class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="glow text-4xl uppercase section-heading" style="font-family:var(--font-display)">Stack</h2>
    <div class="space-y-6">
      {Object.entries(resumeData.skills).map(([key, items]) => (
        <div>
          <p class="skill-label text-xs uppercase tracking-widest text-[var(--accent-2)]">{LABEL_MAP[key] ?? key}</p>
          <div class="skill-row flex flex-wrap">
            {(items as string[]).map((s) => (
              <span>{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <footer id="contact" class="max-w-5xl mx-auto px-6 py-20 text-center">
    <h2 class="glow text-4xl uppercase section-heading justify-center" style="font-family:var(--font-display)">Contact</h2>
    <ThemeContact client:load />
  </footer>
</ThemeLayout>
