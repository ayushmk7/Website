---
// src/pages/v2/bauhaus/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/bauhaus.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const categoryLabels: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};

// Each category gets a distinct geometric icon type + color
const categoryMeta: { icon: string; color: string }[] = [
  { icon: 'sq',     color: 'var(--accent)' },
  { icon: 'dot',    color: 'var(--accent-2)' },
  { icon: 'tri-sm', color: 'var(--bau-yellow)' },
  { icon: 'sq',     color: 'var(--accent-2)' },
  { icon: 'dot',    color: 'var(--accent)' },
  { icon: 'tri-sm', color: 'var(--accent-2)' },
];

const sectionBarColors = ['var(--accent)', 'var(--accent-2)', 'var(--bau-yellow)', 'var(--accent)', 'var(--accent-2)'];
---
<ThemeLayout themeKey="bauhaus" title="Ayush Madhav Kumar. Bauhaus">

  <!-- ========================================================
       HERO: one viewport, photo panel + text column
       ======================================================== -->
  <section class="bau-hero relative">
    <!-- faint grid motif -->
    <div class="bau-grid-motif" aria-hidden="true"></div>

    <div class="bau-hero-grid">
      <!-- decorative shapes: z-index 0 keeps them behind text (z-10) -->
      <div class="shape circle" style="width:clamp(100px,18vw,220px);height:clamp(100px,18vw,220px);top:-30px;right:-20px;z-index:0;pointer-events:none" aria-hidden="true"></div>
      <div class="shape tri"    style="bottom:clamp(10px,3vh,40px);left:30%;z-index:0;pointer-events:none" aria-hidden="true"></div>

      <!-- photo -->
      <div class="bau-photo-panel relative z-10">
        <Photo />
      </div>

      <!-- text -->
      <div class="bau-hero-text relative z-10">
        <div class="h-3 w-24 bg-[var(--accent)] mb-4" data-load aria-hidden="true"></div>
        <p class="bau-hero-tagline" data-load style="--i:1">CS and Math at UMichigan</p>
        <h1 class="bau-hero-name mt-2" data-load style="--i:2">Ayush<br/>Madhav<br/>Kumar</h1>
        <div class="bau-nsf-tag" data-load style="--i:3" aria-label="NSF-backed research">&gt; NSF-backed research</div>
        <a
          class="bau-btn bau-btn-yellow mt-5 w-fit"
          href="/AyushMadhavResume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          data-load
          style="--i:4"
        >Resume</a>
      </div>
    </div>
  </section>

  <!-- ========================================================
       EXPERIENCE
       ======================================================== -->
  <section id="experience" class="max-w-6xl mx-auto px-6 py-20">
    <div class="bau-section-head" style="--section-bar-color:var(--accent)">
      <h2>Experience</h2>
      <div class="bau-section-bar" aria-hidden="true"></div>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      {experience.map((j, i) => (
        <div class="bau-card block p-6 bg-[var(--surface)]" data-load style={`--i:${Math.min(i,4)}`}>
          <div class="h-2 w-12 mb-4" style={i % 2 ? 'background:var(--accent-2)' : 'background:var(--accent)'} aria-hidden="true"></div>
          <p class="uppercase text-sm">{j.period}</p>
          <h3 class="text-2xl uppercase mt-1" style="font-family:var(--font-display);font-weight:700">{j.company}</h3>
          <p class="mt-1">{j.role}</p>
          <ul class="bau-bullets text-sm">
            {j.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ========================================================
       PROJECTS
       ======================================================== -->
  <section id="projects" class="max-w-6xl mx-auto px-6 py-20">
    <div class="bau-section-head" style="--section-bar-color:var(--accent-2)">
      <h2>Projects</h2>
      <div class="bau-section-bar" aria-hidden="true"></div>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {projects.filter((p) => !hackathons.some((h) => h.project === p.title)).map((p, i) => (
        <div class="bau-card block p-6 bg-[var(--surface)]" data-load style={`--i:${Math.min(i,4)}`}>
          <h3 class="text-xl uppercase" style="font-family:var(--font-display);font-weight:700">{p.title}</h3>
          <p class="text-sm mt-3">{p.description}</p>
          {(p.githubUrl || p.websiteUrl) && (
            <div class="flex flex-wrap gap-3 mt-5">
              {p.githubUrl && (
                <a href={p.githubUrl} target="_blank" rel="noopener noreferrer" class="bau-link bau-link--icon" style="color:var(--accent-2)" aria-label={`${p.title} GitHub repository`}>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                </a>
              )}
              {p.websiteUrl && (
                <a href={p.websiteUrl} target="_blank" rel="noopener noreferrer" class="bau-link bau-link--icon" style="color:var(--accent)" aria-label={`${p.title} live site`}>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ========================================================
       HACKATHONS
       ======================================================== -->
  <section id="hackathons" class="max-w-6xl mx-auto px-6 py-20">
    <div class="bau-section-head" style="--section-bar-color:var(--bau-yellow)">
      <h2>Hackathons</h2>
      <div class="bau-section-bar" aria-hidden="true"></div>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      {hackathons.map((h, i) => (
        <div
          class="bau-hack-card bau-card block p-7"
          style={i % 2 ? 'background:var(--accent-2)' : 'background:var(--accent)'}
          data-load
        >
          <p class="uppercase text-sm text-white">{h.placement}</p>
          <h3 class="text-2xl uppercase text-white mt-1" style="font-family:var(--font-display);font-weight:700">{h.event}</h3>
          <p class="text-sm mt-3 text-white">{h.blurb}</p>
          {(h.repoUrl || h.siteUrl) && (
            <div class="flex flex-wrap gap-3 mt-5">
              {h.repoUrl && (
                <a href={h.repoUrl} target="_blank" rel="noopener noreferrer" class="bau-link bau-link--icon" style="color:#ffffff;border-color:#ffffff" aria-label={`${h.project} GitHub repository`}>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                </a>
              )}
              {h.siteUrl && (
                <a href={h.siteUrl} target="_blank" rel="noopener noreferrer" class="bau-link bau-link--icon" style="color:#ffffff;border-color:#ffffff" aria-label={`${h.project} live site`}>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ========================================================
       STACK (skills)
       ======================================================== -->
  <section id="skills" class="max-w-6xl mx-auto px-6 py-20">
    <div class="bau-section-head" style="--section-bar-color:var(--accent)">
      <h2>Stack</h2>
      <div class="bau-section-bar" aria-hidden="true"></div>
    </div>
    <div class="space-y-10">
      {Object.entries(resumeData.skills).map(([key, items], ci) => {
        const meta = categoryMeta[ci % categoryMeta.length];
        return (
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span
                class={`bau-cat-icon ${meta.icon}`}
                style={`--cat-color:${meta.color}`}
                aria-hidden="true"
              ></span>
              <span class="uppercase text-sm tracking-widest" style="font-family:var(--font-display);font-weight:700;color:var(--text)">
                {categoryLabels[key] ?? key}
              </span>
            </div>
            <div class="flex flex-wrap gap-3">
              {(items as string[]).map((s) => (
                <span class="bau-skill">{s}</span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ========================================================
       CONTACT
       ======================================================== -->
  <footer id="contact" class="max-w-6xl mx-auto px-6 py-20">
    <div class="bau-section-head" style="--section-bar-color:var(--accent-2)">
      <h2>Contact</h2>
      <div class="bau-section-bar" aria-hidden="true"></div>
    </div>
    <ThemeContact client:load />
  </footer>

</ThemeLayout>
