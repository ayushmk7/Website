---
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/swiss.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const nonHackathonProjects = projects.filter(p => !hackathons.some(h => h.project === p.title));

const categoryLabels: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};
---

<ThemeLayout themeKey="swiss" title="Ayush Madhav Kumar. Swiss">

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════════════ -->
  <section class="swiss-hero px-6 md:px-12 max-w-7xl mx-auto flex flex-col justify-between" style="padding-top:clamp(3.5rem,10vh,6rem);padding-bottom:clamp(1rem,4vh,2.5rem);">

    <!-- Top bar -->
    <div class="sw-rule sw-wipe" style="margin-bottom:clamp(0.5rem,2vh,2rem);" aria-hidden="true"></div>

    <!-- Content: photo + name block -->
    <div class="flex flex-col md:flex-row md:items-end flex-1" style="gap:clamp(0.75rem,2vh,2.5rem);min-height:0;">

      <!-- Photo (above name on mobile, left on desktop) -->
      <div data-load style="--i:0">
        <Photo class="sw-hero-photo" />
      </div>

      <!-- Name + meta -->
      <div class="flex-1" style="min-width:0;">
        <h1
          class="font-black leading-[0.9] tracking-tight"
          style="font-family:var(--font-display);font-weight:900;font-size:clamp(2.5rem,9vw,8rem);letter-spacing:-0.04em;--i:2"
          data-load
        >
          Ayush<br/>Madhav Kumar
        </h1>
        <hr class="sw-rule-accent sw-wipe" style="margin-top:clamp(0.5rem,2vh,1.5rem);margin-bottom:clamp(0.375rem,1.5vh,1rem);" aria-hidden="true" />
        <p class="text-[var(--text-dim)]" style="font-family:var(--font-display);font-weight:400;font-size:clamp(0.875rem,2vw,1.125rem);--i:3" data-load>
          CS and Math @UMichigan
        </p>
        <p style="font-weight:400;font-size:clamp(0.8125rem,1.8vw,1rem);margin-top:clamp(0.25rem,0.75vh,0.5rem);--i:4" data-load>
          &gt; NSF-backed research
        </p>
        <p style="margin-top:clamp(0.5rem,2vh,1rem);--i:5" data-load>
          <a
            href="/AyushMadhavResume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="sw-resume-btn"
          ><span>Resume</span></a>
        </p>
      </div>

    </div>

    <!-- Bottom rule -->
    <div class="sw-rule sw-wipe" style="margin-top:clamp(0.5rem,2vh,2rem);" aria-hidden="true"></div>

  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       01 EXPERIENCE
  ════════════════════════════════════════════════════════════════════ -->
  <section id="experience" class="max-w-7xl mx-auto px-6 md:px-12 py-20">

    <!-- Section header row -->
    <div class="grid grid-cols-[auto_1fr] items-baseline gap-8 mb-12">
      <span class="sw-numeral" aria-hidden="true">01</span>
      <div>
        <div class="sw-rule sw-wipe mb-4" aria-hidden="true"></div>
        <h2 class="sw-section-title">Experience</h2>
      </div>
    </div>

    <!-- Entries -->
    <div class="pl-0 md:pl-[calc(var(--numeral-size)+2rem)]">
      {experience.map((j, i) => (
        <div class="sw-entry" data-load style={`--i:${Math.min(i, 5)}`}>
          <div class="grid md:grid-cols-[1fr_auto] gap-2 mb-2">
            <h3 style="font-family:var(--font-display);font-weight:900;font-size:1.125rem;">
              {j.company}
            </h3>
            <span class="sw-tag self-start">{j.kind}</span>
          </div>
          <p class="text-[var(--text-dim)] mb-3" style="font-weight:400;font-size:0.9375rem;">
            {j.role} . {j.period}{j.location ? ` . ${j.location}` : ''}
          </p>
          <ul class="space-y-1" style="font-weight:400;line-height:1.6;font-size:0.9375rem;">
            {j.bullets.map(b => (
              <li class="flex gap-3">
                <span class="sw-bullet" aria-hidden="true"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       02 PROJECTS
  ════════════════════════════════════════════════════════════════════ -->
  <section id="projects" class="max-w-7xl mx-auto px-6 md:px-12 py-20">

    <div class="grid grid-cols-[auto_1fr] items-baseline gap-8 mb-12">
      <span class="sw-numeral" aria-hidden="true">02</span>
      <div>
        <div class="sw-rule sw-wipe mb-4" aria-hidden="true"></div>
        <h2 class="sw-section-title">Projects</h2>
      </div>
    </div>

    <div class="pl-0 md:pl-[calc(var(--numeral-size)+2rem)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        {nonHackathonProjects.map((p, i) => (
          <div class="sw-entry pr-0 md:pr-10" data-load style={`--i:${Math.min(i, 5)}`}>
            <h3 style="font-family:var(--font-display);font-weight:900;font-size:1rem;margin-bottom:0.375rem;">
              {p.title}
            </h3>
            <p class="text-[var(--text-dim)]" style="font-weight:400;line-height:1.6;font-size:0.9375rem;">
              {p.description}
            </p>
            {(p.githubUrl || p.websiteUrl) && (
              <div class="sw-project-links mt-3 flex gap-4 flex-wrap">
                {p.githubUrl && (
                  <a
                    href={p.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="sw-project-link"
                  >GitHub</a>
                )}
                {p.websiteUrl && (
                  <a
                    href={p.websiteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="sw-project-link"
                  >Site</a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       03 HACKATHONS
  ════════════════════════════════════════════════════════════════════ -->
  <section id="hackathons" class="max-w-7xl mx-auto px-6 md:px-12 py-20">

    <div class="grid grid-cols-[auto_1fr] items-baseline gap-8 mb-12">
      <span class="sw-numeral" aria-hidden="true">03</span>
      <div>
        <div class="sw-rule sw-wipe mb-4" aria-hidden="true"></div>
        <h2 class="sw-section-title">Hackathons</h2>
      </div>
    </div>

    <div class="pl-0 md:pl-[calc(var(--numeral-size)+2rem)]">
      {hackathons.map((h, i) => (
        <div class="sw-entry" data-load style={`--i:${Math.min(i, 4)}`}>
          <div class="grid md:grid-cols-[1fr_auto] gap-2 mb-1">
            <p class="sw-tag">{h.placement}</p>
            <span class="text-[var(--text-dim)] text-sm" style="font-weight:400;">{h.date}</span>
          </div>
          <h3 style="font-family:var(--font-display);font-weight:900;font-size:1.0625rem;margin-bottom:0.375rem;">
            {h.project} . {h.event}
          </h3>
          <p class="text-[var(--text-dim)] mb-3" style="font-weight:400;line-height:1.6;font-size:0.9375rem;max-width:65ch;">
            {h.blurb}
          </p>
          <div class="flex gap-4 flex-wrap">
            {h.repoUrl && (
              <a
                href={h.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="sw-project-link"
              >Repo</a>
            )}
            {h.siteUrl && (
              <a
                href={h.siteUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="sw-project-link"
              >Site</a>
            )}
          </div>
        </div>
      ))}
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       04 STACK
  ════════════════════════════════════════════════════════════════════ -->
  <section id="skills" class="max-w-7xl mx-auto px-6 md:px-12 py-20">

    <div class="grid grid-cols-[auto_1fr] items-baseline gap-8 mb-12">
      <span class="sw-numeral" aria-hidden="true">04</span>
      <div>
        <div class="sw-rule sw-wipe mb-4" aria-hidden="true"></div>
        <h2 class="sw-section-title">Stack</h2>
      </div>
    </div>

    <div class="pl-0 md:pl-[calc(var(--numeral-size)+2rem)]">
      {Object.entries(resumeData.skills).map(([category, items], i) => (
        <div class="sw-entry" data-load style={`--i:${Math.min(i, 5)}`}>
          <div class="grid md:grid-cols-[220px_1fr] gap-4 items-baseline">
            <span class="sw-stack-label">
              {categoryLabels[category] ?? category}
            </span>
            <p style="font-weight:400;line-height:1.6;font-size:0.9375rem;">
              {(items as string[]).join(', ')}
            </p>
          </div>
        </div>
      ))}
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       05 CONTACT
  ════════════════════════════════════════════════════════════════════ -->
  <footer id="contact" class="max-w-7xl mx-auto px-6 md:px-12 py-24">
    <div class="sw-rule sw-wipe mb-16" aria-hidden="true"></div>
    <div class="grid md:grid-cols-[auto_1fr] gap-8 items-end">
      <p class="sw-numeral" aria-hidden="true" style="color:var(--accent);opacity:0.18;">05</p>
      <div>
        <p class="sw-tag mb-4" data-load style="--i:0">Contact</p>
        <div data-load style="--i:1">
          <ThemeContact client:load />
        </div>
        <div class="sw-rule-accent sw-wipe mt-8" aria-hidden="true"></div>
      </div>
    </div>
  </footer>

  <!-- Scroll-wipe: fires red rule across .sw-wipe elements on entry -->
  <script>
    (function () {
      if (typeof window === 'undefined') return;

      function initWipe() {
        var targets = document.querySelectorAll('.sw-wipe');
        if (!targets.length) return;

        // Respect reduced-motion: skip observer, mark all active immediately
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          targets.forEach(function (el) { el.classList.add('sw-wipe-active'); });
          return;
        }

        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('sw-wipe-active');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.2 });

        targets.forEach(function (el) { io.observe(el); });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWipe);
      } else {
        initWipe();
      }
    })();
  </script>

</ThemeLayout>
