---
// src/pages/v2/comic/index.astro
import ThemeLayout from '../../../layouts/ThemeLayout.astro';
import '../../../styles/themes/comic.css';
import Photo from '../../../components/v2/shared/Photo.astro';
import { ThemeContact } from '../../../components/v2/ThemeContact';
import { experience, hackathons } from '../../../data/v2';
import { projects } from '../../../data/projects';
import resumeData from '../../../data/resume.json';

const categoryLabels: Record<string, string> = {
  programmingLanguages: 'Programming Languages',
  aiMl: 'AI and ML',
  softwareDevelopment: 'Software Development',
  databases: 'Databases and Data Engineering',
  devOps: 'DevOps and Cloud Infrastructure',
  coreCs: 'Core Computer Science',
};
---
<ThemeLayout themeKey="comic" title="Ayush Madhav Kumar. Comic Pop">
  <section class="comic-hero flex flex-col justify-center items-center text-center px-6" style="gap:clamp(0.6rem,2vh,1.5rem)">
    <div class="panel p-2" data-load><Photo class="comic-hero-photo" /></div>
    <div class="bubble px-5 py-2" data-load style="--i:1"><p style="font-weight:800;font-size:clamp(0.85rem,2.2vw,1.125rem)">CS and Math @UMichigan</p></div>
    <h1 class="pop text-[var(--accent)]" data-load style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline);--i:2;font-size:clamp(2.5rem,8vw,6rem);line-height:1">Ayush Madhav Kumar!</h1>
    <p data-load style="--i:3;font-family:var(--font-body);font-weight:800;letter-spacing:0.02em">&gt; NSF-backed research</p>
    <a class="panel" href="/AyushMadhavResume.pdf" target="_blank" rel="noopener noreferrer" data-load style="--i:4;font-family:var(--font-display);background:var(--accent-2);color:#141414;padding:0.4rem 1.6rem;font-size:1.5rem;display:inline-block">Resume</a>
  </section>

  <section id="experience" class="max-w-6xl mx-auto px-4 py-16">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--comic-blue)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Experience</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {experience.map((j, i) => (
        <div class="panel p-5" data-load style={`--i:${Math.min(i,4)}`}>
          <p class="text-sm" style="font-weight:600">{j.period}</p>
          <h3 class="text-3xl text-[var(--accent)]" style="font-family:var(--font-display)">{j.company}</h3>
          <p style="font-weight:700">{j.role}</p>
          <ul class="mt-2 space-y-1 text-sm">{j.bullets.map((b) => <li>- {b}</li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  <section id="projects" class="max-w-6xl mx-auto px-4 py-16">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Projects</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {projects.filter((p) => !hackathons.some((h) => h.project === p.title)).map((p, i) => (
        <div class="panel p-5 flex flex-col" data-load style={`--i:${Math.min(i,4)}`}>
          <h3 class="text-2xl text-[var(--comic-blue)]" style="font-family:var(--font-display)">{p.title}</h3>
          <p class="text-sm mt-2 flex-1">{p.description}</p>
          {(p.githubUrl || p.websiteUrl) && (
            <div class="flex gap-2 mt-4 flex-wrap">
              {p.githubUrl && (
                <a
                  href={p.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="comic-link-btn"
                >
                  GitHub
                </a>
              )}
              {p.websiteUrl && (
                <a
                  href={p.websiteUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="comic-link-btn comic-link-btn--site"
                >
                  Site
                </a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <section id="hackathons" class="max-w-6xl mx-auto px-4 py-16">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--comic-blue)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Hackathons</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {hackathons.map((h, i) => (
        <div class="panel panel--burst p-5 bg-[var(--accent-2)]" data-load style={`--i:${Math.min(i,4)}`}>
          <p class="text-sm" style="font-weight:600">{h.placement}</p>
          <h3 class="text-3xl text-[var(--accent)]" style="font-family:var(--font-display)">{h.event}</h3>
          <p class="text-sm mt-2">{h.blurb}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="skills" class="max-w-6xl mx-auto px-4 py-16">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Stack</h2>
    </div>
    <div class="flex flex-col gap-8">
      {Object.entries(resumeData.skills).map(([key, items]) => (
        <div>
          <h3 class="text-2xl text-[var(--comic-blue)] mb-3" style="font-family:var(--font-display)">
            {categoryLabels[key] ?? key}
          </h3>
          <div class="flex flex-wrap gap-2">
            {(items as string[]).map((s) => (
              <span class="skill-tag">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <footer id="contact" class="max-w-6xl mx-auto px-4 py-20 text-center">
    <div class="section-heading justify-center">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Contact</h2>
    </div>
    <ThemeContact client:load />
  </footer>
</ThemeLayout>
