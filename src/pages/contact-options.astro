---
// src/pages/contact-options.astro  (preview/scratch route for picking a contact design)
import ThemeLayout from '../layouts/ThemeLayout.astro';
import '../styles/themes/comic.css';
import ContactOptions from '../components/v2/ContactOptions';
---
<ThemeLayout themeKey="comic" title="Contact options. Ayush Madhav Kumar">
  <section class="max-w-6xl mx-auto py-24" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Contact options</h2>
    </div>
    <p class="mb-8" style="font-weight:700">Pick a style from the sidebar. Tell me the number and I will wire it into the real Contact section.</p>
    <ContactOptions client:load />
  </section>
</ThemeLayout>
