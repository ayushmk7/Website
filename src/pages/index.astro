---
// src/pages/index.astro
import ThemeLayout from '../layouts/ThemeLayout.astro';
import '../styles/themes/comic.css';
import '../styles/layout-variants.css';
import ComicHero from '../components/v2/ComicHero';
import ComicWorldMap from '../components/v2/ComicWorldMap';
import ExperienceLayouts from '../components/v2/ExperienceLayouts.astro';
import ProjectLayouts from '../components/v2/ProjectLayouts.astro';
import HackathonLayouts from '../components/v2/HackathonLayouts.astro';
import StackLayouts from '../components/v2/StackLayouts.astro';
---
<ThemeLayout themeKey="comic" title="Ayush Madhav Kumar. Comic Pop">
  <ComicHero client:load />

  <section id="experience" class="max-w-6xl mx-auto py-16" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--comic-blue)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Experience</h2>
    </div>
    <ExperienceLayouts />
  </section>

  <section id="projects" class="max-w-6xl mx-auto py-16" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Projects</h2>
    </div>
    <ProjectLayouts />
  </section>

  <section id="hackathons" class="max-w-6xl mx-auto py-16" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--comic-blue)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Hackathons</h2>
    </div>
    <HackathonLayouts />
  </section>

  <section id="skills" class="max-w-6xl mx-auto py-16" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Stack</h2>
    </div>
    <StackLayouts />
  </section>

  <section id="places" class="max-w-6xl mx-auto py-16" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading">
      <h2 class="text-6xl text-[var(--comic-blue)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Places I have been</h2>
    </div>
    <p class="mb-6" style="font-weight:700">Tap a pin for live weather.</p>
    <ComicWorldMap client:visible />
  </section>

  <footer id="contact" class="max-w-6xl mx-auto py-20 text-center" style="padding-left:clamp(1rem,4vw,2rem);padding-right:clamp(1rem,4vw,2rem)">
    <div class="section-heading justify-center" style="margin-bottom:2.5rem">
      <h2 class="text-6xl text-[var(--accent)]" style="font-family:var(--font-display);-webkit-text-stroke:2px var(--outline)">Contact</h2>
    </div>
    <div class="panel panel--burst" style="max-width:50rem;margin:0 auto;padding:clamp(1.5rem,4vw,2.5rem);text-align:center">
      <h3 style="font-family:var(--font-display);font-size:clamp(2rem,5.5vw,3.5rem);line-height:1;margin-bottom:0.6rem;color:var(--accent)">Let's build something</h3>
      <p style="font-weight:700;margin-bottom:1.5rem;color:var(--text)">Open to roles and collabs. Email's fastest.</p>
      <div style="display:flex;gap:0.8rem;flex-wrap:wrap;justify-content:center">
        <button id="copy-email" type="button" class="comic-link-btn" data-email="contactayushmadhav@gmail.com" aria-label="Copy email address" style="height:2.7rem;cursor:pointer">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span class="copy-email-label" aria-live="polite">Copy email</span>
        </button>
        <a class="comic-link-btn" href="https://github.com/ayushmk7" target="_blank" rel="noopener noreferrer" style="height:2.7rem">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          GitHub
        </a>
        <a class="comic-link-btn" href="https://www.linkedin.com/in/ayushmk" target="_blank" rel="noopener noreferrer" style="height:2.7rem">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </a>
        <a class="comic-link-btn" href="/AyushMadhavResume.pdf" target="_blank" rel="noopener noreferrer" style="height:2.7rem">Résumé</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var btn = document.getElementById('copy-email');
      if (!btn) return;
      var label = btn.querySelector('.copy-email-label');
      btn.addEventListener('click', function () {
        var email = btn.getAttribute('data-email');
        navigator.clipboard.writeText(email).then(function () {
          var prev = label.textContent;
          label.textContent = 'Copied to clipboard';
          setTimeout(function () { label.textContent = prev; }, 1800);
        }).catch(function () {
          window.location.href = 'mailto:' + email;
        });
      });
    })();
  </script>

  <script is:inline>
    // Carousels: gentle auto-scroll that pauses while you interact; manual
    // scroll/drag via the comic scrollbar always works. Track holds two copies
    // so the wrap is seamless. Honors prefers-reduced-motion.
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var SPEED = 1.1; // px per frame (~66px/s) — visible continuous loop
      document.querySelectorAll('.cscroll[data-autoscroll]').forEach(function (el) {
        var paused = false;
        ['pointerenter', 'focusin', 'pointerdown', 'touchstart'].forEach(function (e) { el.addEventListener(e, function () { paused = true; }, { passive: true }); });
        ['pointerleave', 'focusout', 'touchend'].forEach(function (e) { el.addEventListener(e, function () { paused = false; }, { passive: true }); });
        if (reduce) return;
        function step() {
          var half = el.scrollWidth / 2;
          if (!paused && half > 0) {
            el.scrollLeft += SPEED;
            if (el.scrollLeft >= half) el.scrollLeft -= half; // seamless wrap -> infinite loop
          }
          requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
    })();
  </script>
</ThemeLayout>
